rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getAppRole() {
      // Look up role from a 'roles' collection where doc ID is the user's email
      // This is more efficient for rules than querying staff with unknown IDs
      return get(/databases/$(database)/documents/roles/$(request.auth.token.email)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'alzaem2002@gmail.com' || 
        request.auth.token.email == 'zayd12345@ghiabi.com' ||
        getAppRole() == 'ADMIN'
      );
    }

    function isTeacher() {
      return isSignedIn() && (getAppRole() == 'TEACHER' || getAppRole() == 'TEACHER_LEADER' || isAdmin());
    }

    function isTeacherLeader() {
      return isSignedIn() && (getAppRole() == 'TEACHER_LEADER' || isAdmin());
    }

    function isAttendanceOfficer() {
      return isSignedIn() && (getAppRole() == 'ATTENDANCE_OFFICER' || isAdmin());
    }

    function isSupervisor() {
      return isSignedIn() && (getAppRole() == 'SUPERVISOR' || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidClass(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.gradeLevel is string && data.gradeLevel.size() > 0
          && (!('homeroomTeacher' in data) || data.homeroomTeacher is string)
          && (!('teacherEmail' in data) || data.teacherEmail is string);
    }

    function isValidStudent(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200
          && isValidId(data.classId)
          && data.className is string
          && data.guardianName is string
          && data.guardianPhone is string
          && data.isActive is bool;
    }

    function isValidSession(data) {
      return (data.date is timestamp || data.date == request.time)
          && data.period is int && data.period >= 1 && data.period <= 10
          && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 100
          && isValidId(data.classId)
          && data.teacherEmail is string;
    }

    function isValidLog(data) {
      return isValidId(data.studentId)
          && isValidId(data.sessionId)
          && isValidId(data.classId)
          && data.teacherEmail is string
          && data.status in ['حاضر', 'غائب', 'متأخر', 'بعذر']
          && (data.timestamp is timestamp || data.timestamp == request.time);
    }

    function isValidStaff(data) {
      return data.fullName is string && data.fullName.size() > 0
          && data.nationalId is string && data.nationalId.size() > 0
          && data.phone is string
          && data.role is string
          && data.email is string
          && (!('appRole' in data) || data.appRole in ['ADMIN', 'TEACHER', 'TEACHER_LEADER', 'ATTENDANCE_OFFICER', 'SUPERVISOR']);
    }

    // --- Rules ---

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidClass(incoming());
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || isTeacherLeader()) && isValidStudent(incoming());
    }

    match /sessions/{sessionId} {
      allow read, list: if isSignedIn() && (isSupervisor() || isAttendanceOfficer() || isTeacherLeader() || resource.data.teacherEmail == request.auth.token.email);
      allow create: if isSignedIn() && (isAttendanceOfficer() || isTeacherLeader() || isAdmin() || incoming().teacherEmail == request.auth.token.email) && isValidSession(incoming());
      allow update: if isSignedIn() && (isAttendanceOfficer() || isTeacherLeader() || isAdmin() || existing().teacherEmail == request.auth.token.email) && isValidSession(incoming()) && (isAdmin() || (incoming().teacherEmail == existing().teacherEmail));
      allow delete: if isAdmin();
    }

    match /attendanceLogs/{logId} {
      allow read, list: if isSignedIn() && (isSupervisor() || isAttendanceOfficer() || isTeacherLeader() || resource.data.teacherEmail == request.auth.token.email);
      allow create: if isSignedIn() && (isAttendanceOfficer() || isTeacherLeader() || isAdmin() || incoming().teacherEmail == request.auth.token.email) && isValidLog(incoming());
      allow update: if isSignedIn() && (isAttendanceOfficer() || isTeacherLeader() || isAdmin() || existing().teacherEmail == request.auth.token.email) && isValidLog(incoming());
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidStaff(incoming());
    }

    match /roles/{roleEmail} {
      allow read: if isSignedIn() && (request.auth.token.email == roleEmail || isAdmin());
      allow write: if isAdmin();
    }
  }
}
